{
  "manifest_version": 3,
  "name": "ArtSiren",
  "version": "1.1.0",
  "version_name": "1.1.0",
  "description": "Know before you buy. See which artists support the cultural boycott of Israel — with verified sources. 229 artists tracked.",

  "permissions": [
    "activeTab",
    "storage"
  ],

  "host_permissions": [
    "*://*.ticketmaster.com/*",
    "*://*.ticketmaster.co.uk/*",
    "*://*.ticketmaster.com.au/*",
    "*://*.ticketmaster.de/*",
    "*://*.ticketmaster.fr/*",
    "*://*.ticketmaster.es/*",
    "*://*.ticketmaster.it/*",
    "*://*.ticketmaster.ca/*",
    "*://*.livenation.com/*",
    "*://*.livenation.com.au/*",
    "*://concerts.livenation.com/*",
    "*://*.stubhub.com/*",
    "*://*.stubhub.ca/*",
    "*://*.stubhub.co.uk/*",
    "*://*.stubhub.com.au/*",
    "*://*.stubhub.in/*",
    "*://seatgeek.com/*",
    "*://*.seatgeek.com/*",
    "*://*.axs.com/*",
    "*://*.vividseats.com/*",
    "*://*.eventbrite.com/*",
    "*://*.seetickets.com/*",
    "*://*.gigantic.com/*",
    "*://*.bandsintown.com/*",
    "*://*.songkick.com/*",
    "*://*.ticketek.com.au/*",
    "*://*.moshtix.com.au/*",
    "*://tixel.com/*",
    "*://*.tixel.com/*",
    "*://*.frontiertouring.com/*",
    "*://*.ticketnetwork.com/*",
    "*://tixr.com/*",
    "*://*.tixr.com/*",
    "*://dice.fm/*",
    "*://*.dice.fm/*",
    "*://*.eventim.com/*",
    "*://*.eventim.de/*",
    "*://*.showclix.com/*",
    "*://universe.com/*",
    "*://*.universe.com/*",
    "*://*.etix.com/*",
    "*://*.alttickets.com/*",
    "*://*.skiddle.com/*",
    "*://*.theticketfactory.com/*",
    "*://*.ticketweb.co.uk/*",
    "*://*.ticketone.it/*",
    "*://*.fnac.com/*",
    "*://*.admission.com/*",
    "*://*.oztix.com.au/*",
    "*://*.trybooking.com/*",
    "*://*.viagogo.com/*",
    "*://*.bookmyshow.com/*",
    "*://www.youtube.com/*",
    "*://youtube.com/*",
    "*://music.youtube.com/*",
    "*://open.spotify.com/*",
    "*://music.apple.com/*",
    "*://*.netflix.com/*",
    "*://*.primevideo.com/*",
    "*://*.disneyplus.com/*"
  ],

  "icons": {
    "16": "logo.png",
    "32": "logo.png",
    "48": "logo.png",
    "128": "logo.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "ArtSiren – Artist Boycott Alerts",
    "default_icon": {
      "16": "logo.png",
      "32": "logo.png",
      "48": "logo.png",
      "128": "logo.png"
    }
  },

  "content_scripts": [
    {
      "matches": [
        "*://*.ticketmaster.com/*",
        "*://*.ticketmaster.co.uk/*",
        "*://*.ticketmaster.com.au/*",
        "*://*.ticketmaster.de/*",
        "*://*.ticketmaster.fr/*",
        "*://*.ticketmaster.es/*",
        "*://*.ticketmaster.it/*",
        "*://*.ticketmaster.ca/*",
        "*://*.livenation.com/*",
        "*://*.livenation.com.au/*",
        "*://concerts.livenation.com/*",
        "*://*.stubhub.com/*",
        "*://*.stubhub.ca/*",
        "*://*.stubhub.co.uk/*",
        "*://*.stubhub.com.au/*",
        "*://*.stubhub.in/*",
        "*://seatgeek.com/*",
        "*://*.seatgeek.com/*",
        "*://*.axs.com/*",
        "*://*.vividseats.com/*",
        "*://*.eventbrite.com/*",
        "*://*.seetickets.com/*",
        "*://*.gigantic.com/*",
        "*://*.bandsintown.com/*",
        "*://*.songkick.com/*",
        "*://*.ticketek.com.au/*",
        "*://*.moshtix.com.au/*",
        "*://tixel.com/*",
        "*://*.tixel.com/*",
        "*://*.frontiertouring.com/*",
        "*://*.ticketnetwork.com/*",
        "*://tixr.com/*",
        "*://*.tixr.com/*",
        "*://dice.fm/*",
        "*://*.dice.fm/*",
        "*://*.eventim.com/*",
        "*://*.eventim.de/*",
        "*://*.showclix.com/*",
        "*://universe.com/*",
        "*://*.universe.com/*",
        "*://*.etix.com/*",
        "*://*.alttickets.com/*",
        "*://*.skiddle.com/*",
        "*://*.theticketfactory.com/*",
        "*://*.ticketweb.co.uk/*",
        "*://*.ticketone.it/*",
        "*://*.fnac.com/*",
        "*://*.admission.com/*",
        "*://*.oztix.com.au/*",
        "*://*.trybooking.com/*",
        "*://*.viagogo.com/*",
        "*://*.bookmyshow.com/*",
        "*://www.youtube.com/*",
        "*://youtube.com/*",
        "*://music.youtube.com/*",
        "*://open.spotify.com/*",
        "*://music.apple.com/*",
        "*://*.netflix.com/*",
        "*://*.primevideo.com/*",
        "*://*.disneyplus.com/*"
      ],
      "js": ["artists-data.js", "content.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["logo.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
